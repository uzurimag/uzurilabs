# Copy this file to .env.local and fill in real values. Never commit .env.local.

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase — placeholders only, replace with real values in .env.local.
# Get these from your Supabase project: Settings > API.

# Public: your project's API URL. Safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url

# Public: the publishable key. Safe to expose to the browser —
# access is enforced by Row Level Security policies, not by keeping this secret.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key

# Server-only: bypasses Row Level Security. Never prefix with NEXT_PUBLIC_,
# never import it into client components, and do not use it until a ticket
# specifically requires privileged server-side access.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
